@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container mt-4">
    <h2 class="neon-glow mb-4"><i class="bi bi-list-ul me-2"></i>My Orders</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag" style="font-size: 4rem; color: var(--muted);"></i>
            <h4 class="mt-3">No orders yet</h4>
            <p class="text-muted">Start shopping to see your orders here!</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-shop me-2"></i>Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 g-3">
            @foreach (var order in Model)
            {
                <div class="col">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start flex-wrap">
                                <div>
                                    <h5 class="fw-bold mb-1">Order #@order.Id</h5>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar me-1"></i>@order.CreatedAt?.ToString("dd MMM yyyy HH:mm")
                                    </small>
                                </div>
                                <div class="text-end">
                                    @{
                                        var badgeClass = order.Status switch
                                        {
                                            "Pending" => "bg-warning",
                                            "Processing" => "bg-primary",
                                            "Shipped" => "bg-info",
                                            "Delivered" => "bg-success",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass mb-1">@order.Status</span>
                                    <div class="fw-bold fs-5" style="color: var(--accent);">@order.FinalPrice.ToString("N2") ฿</div>
                                </div>
                            </div>

                            <hr class="my-2" />

                            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                                @foreach (var item in order.Items.Take(4))
                                {
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 40px; height: 40px; object-fit: cover;" class="rounded" title="@item.ProductName" />
                                    }
                                    else
                                    {
                                        <div style="width: 40px; height: 40px; background: var(--accent-lighter);" class="rounded d-flex align-items-center justify-content-center" title="@item.ProductName">
                                            <i class="bi bi-image" style="color: var(--muted); font-size: 0.7rem;"></i>
                                        </div>
                                    }
                                }
                                @if (order.Items.Count > 4)
                                {
                                    <span class="text-muted small">+@(order.Items.Count - 4) more</span>
                                }
                                <span class="text-muted small ms-2">@order.Items.Count item(s)</span>
                            </div>

                            <div class="text-end">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
