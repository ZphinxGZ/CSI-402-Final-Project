@model OrderViewModel
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container mt-4">
    <div class="text-center py-4">
        <div class="mb-3">
            <i class="bi bi-check-circle-fill" style="font-size: 5rem; color: #10b981;"></i>
        </div>
        <h2 class="fw-bold mb-2">Order Placed Successfully!</h2>
        <p class="text-muted fs-5">Thank you for your order. Your order number is <strong>#@Model.Id</strong></p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Order Summary</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <small class="text-muted">Order Number</small>
                            <p class="fw-bold mb-1">#@Model.Id</p>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Date</small>
                            <p class="fw-bold mb-1">@Model.CreatedAt?.ToString("dd MMM yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Status</small>
                            <p class="mb-1"><span class="badge bg-warning">@Model.Status</span></p>
                        </div>
                        <div class="col-md-6">
                            <small class="text-muted">Total</small>
                            <p class="fw-bold mb-1" style="color: var(--accent);">@Model.FinalPrice.ToString("N2") ฿</p>
                        </div>
                    </div>

                    <hr />

                    <h6 class="fw-bold mb-3">Items</h6>
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center mb-2 p-2 rounded" style="background: var(--accent-lighter);">
                            <div class="me-3">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 40px; height: 40px; object-fit: cover;" class="rounded" />
                                }
                                else
                                {
                                    <div style="width: 40px; height: 40px; background: var(--accent-light);" class="rounded d-flex align-items-center justify-content-center">
                                        <i class="bi bi-image" style="color: var(--muted); font-size: 0.8rem;"></i>
                                    </div>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <span class="fw-500">@item.ProductName</span>
                                <small class="text-muted ms-2">x @item.Quantity</small>
                            </div>
                            <div class="fw-bold">@item.Total.ToString("N2") ฿</div>
                        </div>
                    }

                    <hr />

                    <div class="d-flex justify-content-between mb-1">
                        <span>Subtotal:</span>
                        <span>@Model.TotalPrice.ToString("N2") ฿</span>
                    </div>
                    @if (Model.Discount > 0)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success">
                            <span><i class="bi bi-tag me-1"></i>Discount:</span>
                            <span>-@Model.Discount.ToString("N2") ฿</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between fw-bold fs-5 mt-2">
                        <span>Total:</span>
                        <span style="color: var(--accent);">@Model.FinalPrice.ToString("N2") ฿</span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-center">
                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-primary">
                    <i class="bi bi-list-ul me-2"></i>View My Orders
                </a>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-shop me-2"></i>Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>
