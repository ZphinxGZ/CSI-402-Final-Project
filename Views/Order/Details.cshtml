@model OrderViewModel
@{
    ViewData["Title"] = "Order #" + Model.Id;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="neon-glow mb-0">Order #@Model.Id</h2>
        <a asp-action="MyOrders" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Orders
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-bag-check me-2"></i>Order Items</h5>
                </div>
                <div class="card-body p-0">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center p-3 border-bottom">
                            <div class="me-3">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 60px; height: 60px; object-fit: cover;" class="rounded" />
                                }
                                else
                                {
                                    <div style="width: 60px; height: 60px; background: var(--accent-lighter);" class="rounded d-flex align-items-center justify-content-center">
                                        <i class="bi bi-image" style="color: var(--muted);"></i>
                                    </div>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-0">@item.ProductName</h6>
                                <small class="text-muted">@item.Price.ToString("N2") ฿ x @item.Quantity</small>
                            </div>
                            <div class="fw-bold">@item.Total.ToString("N2") ฿</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Order Info</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <small class="text-muted">Status</small>
                        @{
                            var badgeClass = Model.Status switch
                            {
                                "Pending" => "bg-warning",
                                "Processing" => "bg-primary",
                                "Shipped" => "bg-info",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <div><span class="badge @badgeClass fs-6">@Model.Status</span></div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted">Date</small>
                        <p class="mb-0 fw-500">@Model.CreatedAt?.ToString("dd MMM yyyy HH:mm")</p>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between mb-1">
                        <span>Subtotal:</span>
                        <span>@Model.TotalPrice?.ToString("N2") ฿</span>
                    </div>
                    @if (Model.Discount > 0)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success">
                            <span><i class="bi bi-tag me-1"></i>Discount:</span>
                            <span>-@Model.Discount?.ToString("N2") ฿</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total:</span>
                        <span style="color: var(--accent);">@Model.FinalPrice?.ToString("N2") ฿</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
