<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CSI_402_Final_Project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CSI_402_Final_Project.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo-neon.svg" alt="Logo" width="28" height="28" />
                    <span>Gaming Gear Store</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-3">
                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear"></i>
                                    <span>Admin</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Orders"><i class="bi bi-receipt me-2"></i>Orders</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Products"><i class="bi bi-box me-2"></i>Products</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Promotions"><i class="bi bi-lightning-charge me-2"></i>Promotions</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people me-2"></i>Users</a></li>
                                </ul>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-grid"></i>
                                <span>Products</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Promotions" asp-action="Index">
                                <i class="bi bi-lightning-charge"></i>
                                <span>Promotions</span>
                            </a>
                        </li>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Order" asp-action="MyOrders">
                                    <i class="bi bi-list-ul"></i>
                                    <span>My Orders</span>
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-2 position-relative" asp-area="" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart"></i>
                                <span>Cart</span>
                                <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 0.6em;">
                                    0
                                </span>
                            </a>
                        </li>
                    </ul>

                    
                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle"></i>
                                    <span>@User.Identity?.Name</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-link nav-link d-flex align-items-center gap-2" style="display:inline;">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <span>Logout</span>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i>
                                    <span>Login</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" asp-area="" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i>
                                    <span>Register</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container">
            &copy; 2026 - CSI_402_Final_Project - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["SwalMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: '@(TempData["SwalIcon"]?.ToString() ?? "success")',
                title: '@(TempData["SwalTitle"]?.ToString() ?? "Success")',
                text: '@TempData["SwalMessage"]',
                confirmButtonColor: '#7c3aed',
                background: '#ffffff',
                color: '#2d2a3e'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
