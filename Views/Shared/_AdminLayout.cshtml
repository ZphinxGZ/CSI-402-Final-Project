<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CSI_402_Final_Project.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .admin-sidebar {
            min-height: calc(100vh - 56px);
            background: var(--bg-2, #f8f9fa);
            border-right: 1px solid var(--border, #dee2e6);
        }
        .admin-sidebar .nav-link {
            color: var(--text, #2d2a3e);
            padding: 0.6rem 1rem;
            border-radius: 6px;
            margin-bottom: 2px;
        }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            background: var(--accent, #7c3aed);
            color: white !important;
        }
        .admin-sidebar .nav-link i {
            width: 24px;
            text-align: center;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm border-bottom box-shadow" style="background: var(--bg-2, #f8f9fa);">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-gear" style="color: var(--accent);"></i>
                    <span class="fw-bold">Admin Panel</span>
                </a>
                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-house me-1"></i>Back to Store
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid flex-grow-1">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block admin-sidebar p-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Orders">
                            <i class="bi bi-receipt"></i> Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Products">
                            <i class="bi bi-box"></i> Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Promotions">
                            <i class="bi bi-lightning-charge"></i> Promotions
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-people"></i> Users
                        </a>
                    </li>
                </ul>
            </nav>

            <main class="col-md-10 ms-sm-auto px-4 py-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["SwalMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: '@(TempData["SwalIcon"]?.ToString() ?? "success")',
                title: '@(TempData["SwalTitle"]?.ToString() ?? "Success")',
                text: '@TempData["SwalMessage"]',
                confirmButtonColor: '#7c3aed',
                background: '#ffffff',
                color: '#2d2a3e'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
