@model Product
@{
    ViewData["Title"] = Model.Name ?? "Product Details";
}

<div class="row">
    <div class="col-md-6 mb-4">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded neon-panel" style="object-fit: cover; max-height: 400px; width: 100%;" alt="@Model.Name" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center rounded neon-panel" style="height: 400px;">
                <i class="bi bi-image" style="font-size: 5rem; opacity: 0.5;"></i>
            </div>
        }
    </div>
    <div class="col-md-6">
        <div class="neon-panel p-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                </ol>
            </nav>

            <h1 class="neon-glow mb-2">@Model.Name</h1>
            <p class="text-muted mb-3">
                <i class="bi bi-folder"></i> @Model.Category?.Name
            </p>

            @{
                var discountedPrice = (decimal)(ViewBag.DiscountedPrice ?? (Model.Price ?? 0));
                var hasPromo = discountedPrice < (Model.Price ?? 0);
            }
            <div class="mb-4">
                @if (hasPromo)
                {
                    <div class="text-muted text-decoration-line-through fs-5">@Model.Price?.ToString("N2") ฿</div>
                    <span class="display-5 fw-bold" style="color: var(--accent);">@discountedPrice.ToString("N2") ฿</span>
                    <span class="badge bg-danger fs-6 ms-2">Sale</span>
                }
                else
                {
                    <span class="display-5 fw-bold" style="color: var(--accent);">@Model.Price?.ToString("N2") ฿</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="mb-4">
                    <h5>Description</h5>
                    <p>@Model.Description</p>
                </div>
            }

            <div class="mb-3">
                <span class="badge @(Model.Stock > 0 ? "bg-success" : "bg-secondary")">
                    @if (Model.Stock > 0)
                    {
                        <i class="bi bi-check-circle"></i>
                        <span>In Stock (@Model.Stock available)</span>
                    }
                    else
                    {
                        <i class="bi bi-x-circle"></i>
                        <span>Out of Stock</span>
                    }
                </span>
            </div>

            <div class="d-grid gap-2 d-md-flex">
                <button class="btn btn-primary btn-lg" id="addToCartBtn" @(Model.Stock <= 0 ? "disabled" : "") onclick="addToCart(@Model.Id)">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            const button = document.getElementById('addToCartBtn');
            const originalText = button.innerHTML;
            
            button.disabled = true;
            button.innerHTML = '<i class="bi bi-hourglass-split"></i> Adding...';
            
            $.ajax({
                url: '@Url.Action("AddToCart", "Cart")',
                type: 'POST',
                data: { productId: productId, quantity: 1 },
                success: function(response) {
                    if (response.success) {
                        button.innerHTML = '<i class="bi bi-check-circle"></i> Added!';
                        button.classList.remove('btn-primary');
                        button.classList.add('btn-success');
                        
                        setTimeout(() => {
                            button.innerHTML = originalText;
                            button.classList.remove('btn-success');
                            button.classList.add('btn-primary');
                            button.disabled = false;
                        }, 2000);
                        
                        updateCartCount(response.cartCount);
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message || 'Failed to add item to cart',
                            confirmButtonColor: '#7c3aed',
                            background: '#ffffff',
                            color: '#2d2a3e'
                        });
                        button.innerHTML = originalText;
                        button.disabled = false;
                    }
                },
                error: function() {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Error adding item to cart. Please login first.',
                        confirmButtonColor: '#7c3aed',
                        background: '#ffffff',
                        color: '#2d2a3e'
                    });
                    button.innerHTML = originalText;
                    button.disabled = false;
                }
            });
        }
        
        function updateCartCount(count) {
            const cartCountElement = document.getElementById('cart-count');
            if (cartCountElement) {
                cartCountElement.textContent = count;
                cartCountElement.style.display = count > 0 ? 'inline' : 'none';
            }
        }
    </script>
}
