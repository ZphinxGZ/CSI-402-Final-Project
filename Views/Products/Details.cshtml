@model Product
@{
    ViewData["Title"] = Model.Name ?? "Product Details";
}

<div class="row">
    <div class="col-md-6 mb-4">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded neon-panel" style="object-fit: cover; max-height: 400px; width: 100%;" alt="@Model.Name" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center rounded neon-panel" style="height: 400px;">
                <i class="bi bi-image" style="font-size: 5rem; opacity: 0.5;"></i>
            </div>
        }
    </div>
    <div class="col-md-6">
        <div class="neon-panel p-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
                </ol>
            </nav>

            <h1 class="neon-glow mb-2">@Model.Name</h1>
            <p class="text-muted mb-3">
                <i class="bi bi-folder"></i> @Model.Category?.Name
            </p>

            <div class="mb-4">
                <span class="display-5 fw-bold">@Model.Price?.ToString("N2") ฿</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="mb-4">
                    <h5>Description</h5>
                    <p>@Model.Description</p>
                </div>
            }

            <div class="mb-3">
                <span class="badge @(Model.Stock > 0 ? "bg-success" : "bg-secondary")">
                    @if (Model.Stock > 0)
                    {
                        <i class="bi bi-check-circle"></i>
                        <span>In Stock (@Model.Stock available)</span>
                    }
                    else
                    {
                        <i class="bi bi-x-circle"></i>
                        <span>Out of Stock</span>
                    }
                </span>
            </div>

            <div class="d-grid gap-2 d-md-flex">
                <button class="btn btn-primary btn-lg" @(Model.Stock <= 0 ? "disabled" : "")>
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </a>
            </div>
        </div>
    </div>
</div>
