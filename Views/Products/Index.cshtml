@model List<Product>
@{
    ViewData["Title"] = "Products";
}

<h2 class="mb-3">Products</h2>

@if (ViewData["q"] != null)
{
    <div class="text-muted mb-3">Showing results for: <span class="neon-glow">@ViewData["q"]</span></div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No products yet.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-3">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" class="card-img-top" style="object-fit: cover; height: 180px;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@p.Name</h5>
                        <div class="text-muted">@p.Category?.Name</div>
                        <div class="mt-2 fw-bold">@p.Price?.ToString("N2") ฿</div>
                    </div>
                </div>
            </div>
        }
    </div>
}
