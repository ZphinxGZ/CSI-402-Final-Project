@model User
@{
    ViewData["Title"] = "My Account";
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="neon-panel p-4">
            <div class="text-center mb-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; background: var(--accent-light); border: 2px solid var(--accent);">
                    <i class="bi bi-person" style="font-size: 3rem; color: var(--accent);"></i>
                </div>
                <h4 class="neon-glow mb-1">@Model.Name @Model.Lastname</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <span class="badge @(Model.Role == "Admin" ? "bg-success" : "bg-secondary")">@Model.Role</span>
            </div>

            <div class="list-group list-group-flush">
                <a asp-action="Edit" class="list-group-item list-group-item-action">
                    <i class="bi bi-pencil me-2"></i> Edit Profile
                </a>
                <a asp-action="ChangePassword" class="list-group-item list-group-item-action">
                    <i class="bi bi-key me-2"></i> Change Password
                </a>
                <a asp-action="Addresses" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-geo-alt me-2"></i> Manage Addresses</span>
                    <span class="badge bg-primary">@Model.Shippingaddresses?.Count</span>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="neon-panel p-4 mb-4">
            <h5 class="neon-glow mb-3">Account Information</h5>
            <div class="row">
                <div class="col-md-6 mb-2">
                    <small class="text-muted">First Name</small>
                    <p class="fw-500">@Model.Name</p>
                </div>
                <div class="col-md-6 mb-2">
                    <small class="text-muted">Last Name</small>
                    <p class="fw-500">@Model.Lastname</p>
                </div>
                <div class="col-md-6 mb-2">
                    <small class="text-muted">Email</small>
                    <p class="fw-500">@Model.Email</p>
                </div>
                <div class="col-md-6 mb-2">
                    <small class="text-muted">Phone</small>
                    <p class="fw-500">@(Model.PhoneNumber ?? "Not set")</p>
                </div>
                <div class="col-md-6 mb-2">
                    <small class="text-muted">Member Since</small>
                    <p class="fw-500">@Model.CreatedAt?.ToString("yyyy-MM-dd")</p>
                </div>
            </div>
        </div>

        <div class="neon-panel p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="neon-glow mb-0">Shipping Addresses</h5>
                <a asp-action="AddAddress" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus"></i> Add Address
                </a>
            </div>
            
            @if (Model.Shippingaddresses?.Any() != true)
            {
                <p class="text-muted">No shipping addresses added yet.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var addr in Model.Shippingaddresses.Take(3))
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="mb-1">@addr.Address</p>
                                    <small class="text-muted">@addr.City, @addr.PostalCode</small>
                                </div>
                                <div>
                                    <a asp-action="EditAddress" asp-route-id="@addr.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if (Model.Shippingaddresses.Count > 3)
                {
                    <div class="text-center mt-3">
                        <a asp-action="Addresses" class="btn btn-outline-primary btn-sm">View All Addresses</a>
                    </div>
                }
            }
        </div>
    </div>
</div>
