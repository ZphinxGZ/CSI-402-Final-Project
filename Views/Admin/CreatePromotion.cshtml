@model PromotionViewModel
@{
    ViewData["Title"] = "Create Promotion";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="neon-glow mb-0">Create Promotion</h2>
    <a asp-action="Promotions" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Promotions
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="CreatePromotion" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Promotion Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Summer Sale" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DiscountValue" class="form-label">Discount (%)</label>
                            <div class="input-group">
                                <input asp-for="DiscountValue" class="form-control" placeholder="e.g. 10, 20, 50" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="DiscountValue" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input asp-for="IsGlobal" class="form-check-input" type="checkbox" id="isGlobalCheck" />
                                <label asp-for="IsGlobal" class="form-check-label">
                                    <i class="bi bi-globe me-1"></i>Apply to All Products (Time-based)
                                </label>
                            </div>
                            <small class="text-muted">Enable for festival/campaign promotions that apply to all products.</small>
                        </div>
                    </div>

                    <div id="productSelectionSection" class="mb-4">
                        <label class="form-label fw-bold">Apply to Products</label>
                        <div class="mb-2">
                            <select id="categoryFilter" class="form-select form-select-sm" style="max-width: 300px;">
                                <option value="">-- All Categories --</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="border rounded p-3" style="max-height: 250px; overflow-y: auto; background: var(--bg-1);">
                            @if (!products.Any())
                            {
                                <p class="text-muted mb-0">No products available.</p>
                            }
                            @foreach (var product in products)
                            {
                                <div class="form-check mb-1 product-item" data-category="@product.CategoryId">
                                    <input class="form-check-input" type="checkbox" name="SelectedProductIds"
                                           value="@product.Id" id="product_@product.Id"
                                           @(Model.SelectedProductIds.Contains(product.Id) ? "checked" : "") />
                                    <label class="form-check-label" for="product_@product.Id">
                                        @product.Name
                                        <small class="text-muted">
                                            (@product.Price?.ToString("N2") ฿)
                                            @if (product.Category != null)
                                            {
                                                <span>- @product.Category.Name</span>
                                            }
                                        </small>
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Create Promotion
                        </button>
                        <a asp-action="Promotions" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle product selection when IsGlobal is checked
        var isGlobalCheck = document.getElementById('isGlobalCheck');
        var productSection = document.getElementById('productSelectionSection');

        function toggleProductSection() {
            if (isGlobalCheck.checked) {
                productSection.style.display = 'none';
            } else {
                productSection.style.display = 'block';
            }
        }

        isGlobalCheck.addEventListener('change', toggleProductSection);
        toggleProductSection();

        // Filter products by category
        document.getElementById('categoryFilter').addEventListener('change', function() {
            var catId = this.value;
            var items = document.querySelectorAll('.product-item');
            for (var i = 0; i < items.length; i++) {
                if (catId === '' || items[i].getAttribute('data-category') === catId) {
                    items[i].style.display = 'block';
                } else {
                    items[i].style.display = 'none';
                }
            }
        });
    </script>
}
