@model List<Promotion>
@{
    ViewData["Title"] = "Manage Promotions";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="neon-glow mb-0"><i class="bi bi-lightning-charge me-2"></i>Promotion Management</h2>
    <div>
        <a asp-action="CreatePromotion" class="btn btn-primary">
            <i class="bi bi-plus me-1"></i>New Promotion
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-tag" style="font-size: 4rem; color: var(--muted);"></i>
        <h4 class="mt-3">No promotions yet</h4>
        <a asp-action="CreatePromotion" class="btn btn-primary mt-2">Create First Promotion</a>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Discount</th>
                        <th>Period</th>
                        <th>Products</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var promo in Model)
                    {
                        <tr>
                            <td>@promo.Id</td>
                            <td>
                                <div class="fw-bold">@promo.Name</div>
                                @if (!string.IsNullOrWhiteSpace(promo.Description))
                                {
                                    <small class="text-muted">@promo.Description</small>
                                }
                            </td>
                            <td>
                                @if (promo.DiscountType == "percentage")
                                {
                                    <span class="badge bg-primary">@promo.DiscountValue%</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">@promo.DiscountValue?.ToString("N0") ฿</span>
                                }
                            </td>
                            <td>
                                <small>@promo.StartDate?.ToString("dd MMM yyyy")</small><br />
                                <small>@promo.EndDate?.ToString("dd MMM yyyy")</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@promo.Promotionproducts.Count product(s)</span>
                            </td>
                            <td>
                                @if (promo.IsActive == true)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="EditPromotion" asp-route-id="@promo.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="DeletePromotion" method="post" class="d-inline" onsubmit="return confirmDelete(event, '@promo.Name')">
                                        <input type="hidden" name="id" value="@promo.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        function confirmDelete(e, name) {
            e.preventDefault();
            Swal.fire({
                title: 'Delete Promotion?',
                text: `Are you sure you want to delete "${name}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#9794a8',
                confirmButtonText: 'Yes, Delete',
                background: '#ffffff',
                color: '#2d2a3e'
            }).then((result) => {
                if (result.isConfirmed) {
                    e.target.closest('form').submit();
                }
            });
            return false;
        }
    </script>
}
