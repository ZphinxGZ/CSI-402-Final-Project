@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="neon-glow mb-4">Admin Dashboard</h2>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <div class="col">
        <div class="neon-panel p-4 h-100">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-people fs-1 me-3" style="color: #b100ff;"></i>
                <div>
                    <h5 class="mb-1">User Management</h5>
                    <p class="text-muted mb-0">Manage users and roles</p>
                </div>
            </div>
            <a asp-action="Users" class="btn btn-primary w-100">
                <i class="bi bi-arrow-right"></i> Manage Users
            </a>
        </div>
    </div>
</div>
