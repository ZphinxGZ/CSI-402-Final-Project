@model List<Product>
@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-4 neon-glow">Gaming Gear Store</h1>
    <p class="lead">Premium gaming equipment for serious gamers</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No products available yet.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 product-card">
                    @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" class="card-img-top" style="object-fit: cover; height: 220px;" alt="@p.Name" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 220px; background: rgba(124, 58, 237, 0.1);">
                            <i class="bi bi-image" style="font-size: 3rem; color: var(--muted);"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="text-muted mb-2">@p.Category?.Name</p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5">@p.Price?.ToString("N2") ฿</span>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light">
            <i class="bi bi-grid"></i> View All Products
        </a>
    </div>
}

<style>
    .product-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(177, 0, 255, 0.25);
    }
</style>
