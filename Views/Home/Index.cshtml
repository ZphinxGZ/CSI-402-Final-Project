@model List<Product>
@{
    ViewData["Title"] = "Home";
}

<div class="hero-section mb-4">
    <h1 class="display-4 fw-bold">Gaming Gear Store</h1>
    <p class="lead mb-4">Premium gaming equipment for serious gamers</p>
    <a asp-controller="Products" asp-action="Index" class="btn btn-light btn-lg px-4">
        <i class="bi bi-grid me-2"></i>Browse Products
    </a>
</div>

<h3 class="fw-bold mb-3"><i class="bi bi-stars me-2" style="color: var(--accent);"></i>Featured Products</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">No products available yet.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 product-card">
                    @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" class="card-img-top" style="object-fit: cover; height: 220px;" alt="@p.Name" />
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 220px; background: var(--accent-lighter);">
                            <i class="bi bi-image" style="font-size: 3rem; color: var(--muted);"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@p.Name</h5>
                        <p class="text-muted mb-2">@p.Category?.Name</p>
                        <div class="mt-auto">
                            @{
                                var dMap = ViewBag.DiscountMap as Dictionary<int, decimal>;
                                var dPrice = dMap != null && dMap.ContainsKey(p.Id) ? dMap[p.Id] : (p.Price ?? 0);
                                var hasDsc = dPrice < (p.Price ?? 0);
                            }
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    @if (hasDsc)
                                    {
                                        <small class="text-muted text-decoration-line-through">@p.Price?.ToString("N2") ฿</small><br />
                                        <span class="fw-bold fs-5" style="color: var(--accent);">@dPrice.ToString("N2") ฿</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold fs-5" style="color: var(--accent);">@p.Price?.ToString("N2") ฿</span>
                                    }
                                </div>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@p.Id" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary btn-lg">
            <i class="bi bi-grid me-2"></i>View All Products
        </a>
    </div>
}
